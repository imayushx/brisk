# ════════════════════════════════════════════════════════════════
# BRISK SECURITY CONFIG — Copy to .env and fill in your secrets
# NEVER commit .env to git — only commit .env.example
# ════════════════════════════════════════════════════════════════

# FINNHUB API (Stock Price Data)
# Get free key at https://finnhub.io
FINNHUB_KEY=your_finnhub_api_key_here
FINNHUB_RATE_LIMIT=60
FINNHUB_RATE_LIMIT_WINDOW=60000

# SUPABASE AUTHENTICATION (Login/Auth)
# Get from https://supabase.io — use your anon/public key only
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# RATE LIMITING (Security)
# Global rate limits per IP address
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_KEY_PREFIX=brisk_

# API ENDPOINTS
API_PRICE_ENDPOINT=/api/price
API_QUOTE_ENDPOINT=/api/quote

# ENVIRONMENT
NODE_ENV=production
LOG_LEVEL=info
